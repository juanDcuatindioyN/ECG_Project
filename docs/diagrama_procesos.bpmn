          <dc:Bounds x="538" y="473" width="75" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_end_ok" bpmnElement="end_ok">
        <dc:Bounds x="1862" y="465" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1872" y="508" width="16" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t3" bpmnElement="t3">
        <dc:Bounds x="740" y="130" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t5" bpmnElement="t5">
        <dc:Bounds x="1140" y="130" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t7" bpmnElement="t7">
        <dc:Bounds x="1440" y="130" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t2" bpmnElement="t2">
        <dc:Bounds x="660" y="300" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t4" bpmnElement="t4">
        <dc:Bounds x="900" y="300" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t6" bpmnElement="t6">
        <dc:Bounds x="1140" y="300" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t8" bpmnElement="t8">
        <dc:Bounds x="1380" y="300" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t9" bpmnElement="t9">
        <dc:Bounds x="1620" y="300" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t10" bpmnElement="t10">
        <dc:Bounds x="1620" y="440" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_gw1" bpmnElement="gw1" isMarkerVisible="true">
        <dc:Bounds x="555" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="547" y="291" width="65" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_t1" bpmnElement="t1">
        <dc:Bounds x="340" y="140" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_ann2" bpmnElement="ann2">
        <dc:Bounds x="660" y="430" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_ann3" bpmnElement="ann3">
        <dc:Bounds x="900" y="430" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_ann4" bpmnElement="ann4">
        <dc:Bounds x="1140" y="430" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sh_ann5" bpmnElement="ann5">
        <dc:Bounds x="1620" y="560" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="e01" bpmnElement="f01">
        <di:waypoint x="288" y="170" />
        <di:waypoint x="314" y="170" />
        <di:waypoint x="314" y="180" />
        <di:waypoint x="340" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e02" bpmnElement="f02">
        <di:waypoint x="420" y="220" />
        <di:waypoint x="420" y="340" />
        <di:waypoint x="555" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_no" bpmnElement="f_no">
        <di:waypoint x="580" y="365" />
        <di:waypoint x="580" y="430" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="586" y="390" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_si" bpmnElement="f_si">
        <di:waypoint x="605" y="340" />
        <di:waypoint x="660" y="340" />
